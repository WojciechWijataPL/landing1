# === Odbiór leadów (kreator wyceny + sekcja kontakt) ===
# POST JSON. Najszybciej: Google Apps Script (patrz docs/BACKEND.md) — URL /exec.
# Alternatywa: n8n Webhook. Na Vercel dodaj w Project Settings → Env Variables.
NEXT_PUBLIC_WEBHOOK_URL=https://script.google.com/macros/s/AKfy.../exec

# === Analityka (opcjonalne) ===
# Puste = skrypt się nie ładuje (zero cookies, zero błędów).
# GA4: Administracja → Strumienie danych → skopiuj "Identyfikator pomiaru".
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
# Meta Pixel: Menedżer zdarzeń → Źródła danych → ID piksela.
NEXT_PUBLIC_FB_PIXEL_ID=000000000000000
